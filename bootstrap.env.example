# Создать .env и .env.mws.local из примеров в корне репозитория: make bootstrap-env
# PPTX: ссылка «Скачать презентацию» в чате должна открываться в браузере. Локально —
# опубликованный порт оркестратора (8089). Для ВМ/облака замените на http://ПУБЛИЧНЫЙ_IP:8089
PPTX_ARTIFACTS_PUBLIC_BASE_URL=http://127.0.0.1:8089
RAG_EMBEDDING_ENGINE=openai
RAG_OPENAI_API_BASE_URL=http://embedding-shim:8000/v1
RAG_OPENAI_API_KEY=replace-with-embedding-api-key
RAG_EMBEDDING_MODEL=qwen3-embedding-8b
BGE_EMBEDDING_UPSTREAM=https://api.example.com/v1

LITELLM_MASTER_KEY=replace-with-same-value-as-litellm-master-key
ORCHESTRATOR_API_KEY=replace-with-same-value-as-litellm-master-key
OPENAI_API_KEY=replace-with-same-value-as-litellm-master-key
WEBUI_SECRET_KEY=replace-with-webui-secret


MWS_GPT_API_BASE=https://api.example.com/v1
MWS_GPT_API_KEY=replace-with-upstream-api-key


CLASSIFIER_SEMANTIC_ENABLED=true
CLASSIFIER_SEMANTIC_MIN_SIMILARITY=0.38
CLASSIFIER_SEMANTIC_MIN_MARGIN=0.02
CLASSIFIER_SEMANTIC_OVERRIDE_LOCKED_HEURISTIC=false # pptx, deep_research, greeting

OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:v0.8.12
# Optional patched image: set your own GHCR tag in real .env (not committed).
# Стриминг: в compose для open-webui задан CHAT_STREAM_RESPONSE_CHUNK_MAX_BUFFER_SIZE (64 MiB);
# при своём запуске WebUI без этого compose — продублируйте, иначе aiohttp или skip_mode ломают ответ.


ORCHESTRATOR_WEBUI_STATUS_ENABLED=true
ORCHESTRATOR_WEBUI_BASE_URL=http://gpthub-prod-open-webui:8080
GPTHUB_INTERNAL_EVENT_SECRET=replace-with-long-random-string
TAVILY_API_KEY=replace-with-tavily-api-key
ENABLE_WEB_SEARCH=true
WEB_SEARCH_ENGINE=tavily