# Copy to .env and keep secrets out of git.

# Shared auth
LITELLM_MASTER_KEY=replace-with-long-random-string
ORCHESTRATOR_API_KEY=replace-with-same-value-as-litellm-master-key
OPENAI_API_KEY=replace-with-same-value-as-litellm-master-key
WEBUI_SECRET_KEY=replace-with-webui-secret

# Open WebUI defaults
WEBUI_URL=http://localhost:3000
ENABLE_SIGNUP=true
DEFAULT_USER_ROLE=user
ENABLE_PERSISTENT_CONFIG=true
DEFAULT_MODELS=gpt-hub
DEFAULT_PINNED_MODELS=gpt-hub
TASK_MODEL_EXTERNAL=gpt-hub
BYPASS_MODEL_ACCESS_CONTROL=true
ENABLE_MEMORIES=false
WEBUI_BANNERS=[]

# Orchestrator
AUTO_ROUTE_MODEL=true
CODE_ROUTE_PREFERENCE=local
LITELLM_TIMEOUT_SECONDS=600
ORCHESTRATOR_LITELLM_FALLBACK=true
ORCHESTRATOR_FALLBACK_MAX_ATTEMPTS=4
ORCHESTRATOR_MODELS_CATALOG=single_public
ORCHESTRATOR_PUBLIC_MODEL_ID=gpt-hub
INGEST_ENABLED=true
# ASR: leave ORCHESTRATOR_ASR_BASE_URL and _API_KEY EMPTY — orchestrator will
# fall back to MWS_GPT_API_BASE / MWS_GPT_API_KEY from .env.mws.local.
# Set explicit values here only if you want a non-MWS whisper host.
ORCHESTRATOR_ASR_BASE_URL=
ORCHESTRATOR_ASR_API_KEY=
ORCHESTRATOR_ASR_MODEL=whisper-medium
ORCHESTRATOR_REQUEST_REASONING_EXCLUDE=true
ORCHESTRATOR_STRIP_REASONING_FROM_RESPONSE=true
ORCHESTRATOR_STRIP_KNOWN_COT_PREAMBLE=false
INJECT_REQUEST_DATETIME=true
ORCHESTRATOR_CLOCK_TZ=UTC
GREETING_CANNED_RESPONSE_ENABLED=false
GREETING_CANNED_MESSAGE=Hello! How can I help?

# PPTX slide-plan LLM (optional hints; default auto/concise)
# PPTX_PLAN_TIMEOUT_SECONDS=300  # whole PPTX path (outline + per-slide LLM + build); max 600
# PPTX_PLAN_TONE=auto
# PPTX_PLAN_AUDIENCE=auto
# PPTX_PLAN_SCENARIO=auto
# PPTX_PLAN_TEXT_CONTENT=concise
# PPTX_SLIDE_AGENTS_CONCURRENCY=7  # parallel per-slide LLM calls (default 7)
# PPTX_MAX_SLIDES=10               # 1–10 only (hard cap in pptx/schema MAX_SLIDES)
# PPTX_INTRO_SLIDE_ENABLED=true    # prepend title slide (topic from first planned slide); layout probed per slide
# Bundled .pptx themes under apps/orchestrator/assets/pttx (copied to /app/assets/pttx in Docker)
# PPTX_ASSET_TEMPLATES_ENABLED=true
# PPTX_TEMPLATES_DIR=   # override directory; empty = auto
# PPTX_TEMPLATE_INDEX=0 # which file when sorted by name (0 = first)
# Public base for markdown download links (browser must reach this host:orchestrator_port). Empty = use request URL (often wrong behind Docker).
# PPTX_ARTIFACTS_PUBLIC_BASE_URL=http://localhost:8089
# PPTX_ARTIFACT_TTL_SECONDS=3600

# RAG (--profile rag): без этих строк WebUI не поднимет embedding_function → PDF/RAG падает с
# AttributeError: 'NoneType' object has no attribute 'encode'
# Закомментировать если стек без profile rag.
RAG_EMBEDDING_ENGINE=openai
RAG_OPENAI_API_BASE_URL=http://embedding-shim:8000/v1
RAG_OPENAI_API_KEY=local-embedding
RAG_EMBEDDING_MODEL=bge-m3
# Host only — shim appends /v1/embeddings (do not end with /v1). MWS: https://api.gpt.mws.ru
BGE_EMBEDDING_UPSTREAM=http://host.docker.internal:9001
RAG_EXTERNAL_RERANKER_URL=http://host.docker.internal:9002/v1/rerank
RAG_EXTERNAL_RERANKER_API_KEY=

# Optional WebUI-managed search
ENABLE_WEB_SEARCH=false
WEB_SEARCH_ENGINE=tavily
TAVILY_API_KEY=
